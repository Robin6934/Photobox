@page "/allPictures"
@attribute [StreamRendering]

<PageTitle>Weather</PageTitle>

<h1>Weather</h1>

<p>This component demonstrates showing data.</p>

@if (pictures == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <body style="background-color: black">
        @foreach (var picture in pictures)
        {
            <div class="image-container">
                <img src="/Images/@picture.name" alt="@picture.name"/>
                @* <a class="print-link1" href="javascript:void(0);" @onclick="ConfirmPrint">Print</a> *@ 
                <button class="Download-button" onclick="/Pictures/Download/@picture.name">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         height="16"
                         width="20"
                         viewBox="0 0 640 512">
                        <path d="M144 480C64.5 480 0 415.5 0 336c0-62.8 40.2-116.2 96.2-135.9c-.1-2.7-.2-5.4-.2-8.1c0-88.4 71.6-160 160-160c59.3 0 111 32.2 138.7 80.2C409.9 102 428.3 96 448 96c53 0 96 43 96 96c0 12.2-2.3 23.8-6.4 34.6C596 238.4 640 290.1 640 352c0 70.7-57.3 128-128 128H144zm79-167l80 80c9.4 9.4 24.6 9.4 33.9 0l80-80c9.4-9.4 9.4-24.6 0-33.9s-24.6-9.4-33.9 0l-39 39V184c0-13.3-10.7-24-24-24s-24 10.7-24 24V318.1l-39-39c-9.4-9.4-24.6-9.4-33.9 0s-9.4 24.6 0 33.9z"
                              fill="white" />
                    </svg>
                    <span>Download</span>
                </button> 
            </div>
        }
    </body>
}

@code {
    private Picture[]? pictures;

    private string PicturePath = Program.PhotoBoxDirectory; // Change to the path where your images are stored

    protected override async Task OnInitializedAsync()
    {
        FileInfo[] files = new DirectoryInfo(PicturePath).GetFiles();

        string[] picturePaths = files.OrderByDescending(file => file.CreationTime).Select(file => file.FullName).ToArray();

        pictures = new Picture[picturePaths.Length];

        Parallel.For(0, picturePaths.Length, i => pictures[i] = new Picture() { name = Path.GetFileName(picturePaths[i]) });
    }

    private void ConfirmPrint()
    {
        Console.WriteLine("Print");
    }

    public class Picture
    {
        public string name { get; set; }
    }
}
